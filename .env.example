# ─────────────────────────────────────────────────────────────
# 상권 AI — API 키 템플릿
# 이 파일을 복사해 같은 폴더에 `.env` 로 저장하고 값을 채우세요.
#   cp .env.example .env
# `.env` 는 .gitignore 처리되어 절대 커밋되지 않습니다.
# ─────────────────────────────────────────────────────────────

# [빌드 시] 공공데이터포털 — 소상공인시장진흥공단 상가(상권) 정보 API
#   발급: https://www.data.go.kr  (storeListInDong)
#   사용: node app/build/collect-store-api.js
PUBLIC_DATA_STORE_API_KEY=

# [빌드 시] 공정거래위원회 — 가맹사업거래 브랜드 API
#   발급: https://www.data.go.kr  (가맹사업정보)
#   사용: node app/build/collect-franchise-brand-dictionary.js
FAIRTRADE_FRANCHISE_API_KEY=

# [런타임] Gemini API 키
#   배포된 공개 사이트에서는 방문자가 우측 '설정' 모달에서 각자 입력합니다(권장).
#   로컬 개발에서 자동 주입하려면 .env 가 아니라 app/env.local.js 를 사용하세요.
#   → app/env.local.example.js 참고. (정적 사이트에는 비밀키를 넣지 마세요.)
